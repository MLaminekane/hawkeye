{
  "name": "@mklamine/hawkeye-core",
  "version": "0.2.1",
  "description": "Core SDK for Hawkeye — recording, interception, drift detection, guardrails, memory diff, autocorrect, and swarm orchestration",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MLaminekane/hawkeye.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "node ../../scripts/ensure-supported-node.cjs && node ../../scripts/require-pnpm-publish.cjs && npm run build && node ../../scripts/check-publish-manifests.cjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.1",
    "chokidar": "^4.0.3",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/uuid": "^10.0.0",
    "vitest": "^3.2.6"
  }
}
