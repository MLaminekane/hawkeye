{
  "name": "hawkeye",
  "version": "0.1.0",
  "private": true,
  "description": "The flight recorder for AI agents",
  "scripts": {
    "dev": "turbo dev",
    "predev": "node scripts/ensure-supported-node.cjs && node scripts/ensure-pnpm.cjs",
    "build": "turbo build",
    "prebuild": "node scripts/ensure-supported-node.cjs && node scripts/ensure-pnpm.cjs",
    "test": "turbo test",
    "pretest": "node scripts/ensure-supported-node.cjs && node scripts/ensure-pnpm.cjs",
    "lint": "turbo lint",
    "prelint": "node scripts/ensure-supported-node.cjs && node scripts/ensure-pnpm.cjs",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "check:publish": "node scripts/check-publish-manifests.cjs"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100,
    "tabWidth": 2
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "prettier": "^3.4.2",
    "turbo": "^2.9.14",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@>=5.0.0 <5.0.6": "5.0.6",
      "@hono/node-server@<1.19.13": "1.19.13",
      "esbuild@>=0.17.0 <0.28.1": "0.28.1",
      "fast-uri@<=3.1.1": "3.1.2",
      "flatted@<=3.4.1": "3.4.2",
      "hono@<4.12.21": "4.12.25",
      "ip-address@<=10.1.0": "10.2.0",
      "lodash@>=4.0.0 <=4.17.23": "4.18.1",
      "path-to-regexp@>=8.0.0 <8.4.0": "8.4.2",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "postcss@<8.5.10": "8.5.15",
      "qs@>=6.11.1 <=6.15.1": "6.15.2",
      "vite@>=6.0.0 <=6.4.1": "6.4.3"
    }
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
